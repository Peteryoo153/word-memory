{
  "expo": {
    "name": "단어암기장",
    "slug": "word-memo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "wordmemo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.peteryoo153.wordmemo",
      "infoPlist": {
        "CFBundleDisplayName": "단어암기장",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.80364629052-foutf6riq3eo56qgm5f1bek34j9q2i4p",
              "com.googleusercontent.apps.80364629052-n5g5hjt60nnptv6fskdks5oabpuub5sm"
            ]
          },
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.80364629052-foutf6riq3eo56qgm5f1bek34j9q2i4p",
              "com.googleusercontent.apps.80364629052-n5g5hjt60nnptv6fskdks5oabpuub5sm"
            ]
          }
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.peteryoo153.wordmemo"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/cover.png",
          "resizeMode": "cover",
          "backgroundColor": "#FDFBF0",
          "dark": {
            "backgroundColor": "#FDFBF0"
          }
        }
      ],
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "color": "#2952CC"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e5ca9d91-c53a-4d7c-8bbd-7a38ca713537"
      }
    }
  }
}
